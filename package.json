{
    "name": "vibecalendar",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:server": "node --watch server/index.js",
        "dev:full": "concurrently \"npm run dev:server\" \"npm run dev\"",
        "setup:dev": "node tools/setup-dev.mjs",
        "seed:sample": "node server/seed_from_sample.js",
        "verify:demo": "node tools/verify-demo-data.mjs",
        "start:easy": "npm run setup:dev && npm run dev:full",
        "present": "node tools/present.mjs",
        "db:migrate": "node server/migrate.js",
        "build": "tsc -b && vite build",
        "preview": "vite preview"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.1",
        "googleapis": "^144.0.0",
        "jsonwebtoken": "^9.0.2",
        "@azure/msal-node": "^3.8.0",
        "node-cron": "^3.0.3",
        "node-ical": "^0.20.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "sqlite": "^5.1.1",
        "sqlite3": "^5.1.7",
        "uuid": "^11.0.2",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/react": "^18.3.8",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "concurrently": "^9.0.1",
        "typescript": "^5.6.2",
        "vite": "^5.4.10"
    }
}
